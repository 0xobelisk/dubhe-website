{
  "$schema": "https://turbo.build/schema.json",
  "ui": "tui",
  "globalEnv": [
    "ANALYZE",
    "CI",
    "DEBUG_KEY",
    "NEXT_CONFIG_ENV",
    "NEXT_RUNTIME",
    "NODE_ENV",
    "RESEND_API_KEY",
    "RESEND_FROM_EMAIL",
    "RESEND_TO_EMAIL",
    "SENTRY_ORG",
    "SENTRY_PROJECT",
    "VERCEL_ENV",
    "VERCEL_GIT_COMMIT_SHA"
  ],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "inputs": ["$TURBO_DEFAULT$", ".env*"],
      "outputs": [".next/**", "!.next/cache/**"]
    },
    "lint": {
      "dependsOn": ["^lint"]
    },
    "check-types": {
      "dependsOn": ["^check-types"]
    },
    "test": {
      "dependsOn": ["^test"],
      "outputs": ["coverage/**"]
    },
    "test:unit": {
      "dependsOn": ["^test:unit"],
      "outputs": ["coverage/**"]
    },
    "test:e2e": {
      "dependsOn": ["^test:e2e"],
      "outputs": ["playwright-report/**", "test-results/**"]
    },
    "test:performance": {
      "dependsOn": ["^test:performance"],
      "outputs": ["lighthouse-ci-results/**", "lighthouse-report.html"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    }
  }
}
